{
  "permissions": {
    "allow": [
      "Bash(*)",
      "mcp__context7",
      "mcp__memory",
      "mcp__repomix",
      "mcp__codex__codex",
      "mcp__codex__codex-reply",
      "mcp__firecrawl",
      "mcp__chrome-devtools",
      "mcp__postgresql",
      "mcp__grok-search",
      "WebSearch",
      "WebFetch",
      "Write",
      "Edit",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(pip install*)",
      "Bash(pip3 install*)",
      "Bash(python -m pip install*)",
      "Bash(python3 -m pip install*)",
      "Bash(python -m venv*)",
      "Bash(python3 -m venv*)",
      "Bash(virtualenv *)",
      "Bash(npm install*)",
      "Bash(npm i *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(bun install*)",
      "Bash(bun add*)",
      "Bash(uv pip*)",
      "Bash(uv venv*)",
      "Bash(poetry install*)",
      "Bash(poetry add*)",
      "Bash(conda install*)",
      "Bash(conda create*)",
      "Bash(pip *install*)",
      "Bash(source */activate)",
      "Bash(source venv/bin/activate*)",
      "Bash(. venv/bin/activate*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push *--force*)",
      "Bash(git push *-f *)",
      "Bash(git push *+*:*)",
      "Bash(git reset --hard*)",
      "Bash(git checkout .)",
      "Bash(git checkout -- .)",
      "Bash(git restore .)",
      "Bash(git restore --staged .)",
      "Bash(git clean -f*)",
      "Bash(git clean -df*)",
      "Bash(git clean -fd*)",
      "Bash(git branch -D*)",
      "Bash(git rebase *main*)",
      "Bash(git rebase *master*)",
      "Bash(git update-ref*)",
      "Bash(git add -A*)",
      "Bash(git add --all*)",
      "Bash(git add .)",
      "Bash(git add . *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(sudo *)",
      "Bash(curl*|*bash*)",
      "Bash(wget*|*bash*)",
      "Bash(curl*|*sh*)",
      "Bash(wget*|*sh*)",
      "Bash(cat .env*)",
      "Bash(cat */.env*)",
      "Bash(less .env*)",
      "Bash(less */.env*)",
      "Bash(head .env*)",
      "Bash(head */.env*)",
      "Bash(tail .env*)",
      "Bash(tail */.env*)",
      "Bash(more .env*)",
      "Bash(more */.env*)",
      "Bash(grep * .env*)",
      "Bash(grep * */.env*)",
      "Bash(sed * .env*)",
      "Bash(awk * .env*)",
      "Read(.env*)",
      "Read(*/.env*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/verify-step-guard.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/enforce-extension-pattern.py"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-git-pull-pre.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/file-protection.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/security-scan.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/restrict-cwd-edits.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/memory-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-dangerous-git.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-host-installs.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-format.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/check-extension-imports.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-git-push.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/memory-warn.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/implementation-checklist-pending.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/verify-step-pending.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/data-retention.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-git-pull.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/task-progress-check.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/detect-extension-project.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/firecrawl-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-continue-until-green.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/precompact-backup-session.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/precompact-build-restore-note.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/promote-lessons.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/idle-notify.sh"
          }
        ]
      },
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/permission-notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "cat | bash ~/.claude/statusline.sh",
    "padding": 0
  },
  "extraKnownMarketplaces": {
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    }
  },
  "effortLevel": "high",
  "enabledPlugins": {
    "feature-dev@claude-code-plugins": true
  }
}
