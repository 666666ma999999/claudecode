{
  "cleanupPeriodDays": 365,
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "30",
    "ENABLE_TOOL_SEARCH": "auto:5",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "mcp__context7",
      "mcp__memory",
      "mcp__repomix",
      "mcp__codex__codex",
      "mcp__codex__codex-reply",
      "mcp__chrome-devtools",
      "mcp__playwright",
      "mcp__postgresql",
      "mcp__google-search-console",
      "Monitor",
      "WebSearch",
      "WebFetch",
      "Write",
      "Edit",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(env)",
      "Bash(env *)",
      "Bash(printenv)",
      "Bash(printenv *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push *--force*)",
      "Bash(git push *-f *)",
      "Bash(git push *+*:*)",
      "Bash(git reset --hard*)",
      "Bash(git checkout .)",
      "Bash(git checkout -- .)",
      "Bash(git restore .)",
      "Bash(git restore --staged .)",
      "Bash(git clean -f*)",
      "Bash(git clean -df*)",
      "Bash(git clean -fd*)",
      "Bash(git branch -D*)",
      "Bash(git rebase *main*)",
      "Bash(git rebase *master*)",
      "Bash(git update-ref*)",
      "Bash(git add -A*)",
      "Bash(git add --all*)",
      "Bash(git add .)",
      "Bash(git add . *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(sudo *)",
      "Bash(curl*|*sh*)",
      "Bash(wget*|*sh*)",
      "Bash(cat *.env*)",
      "Bash(less *.env*)",
      "Bash(head *.env*)",
      "Bash(tail *.env*)",
      "Bash(more *.env*)",
      "Bash(grep * *.env*)",
      "Bash(sed * *.env*)",
      "Bash(awk * *.env*)",
      "Read(*.env*)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.gnupg/*)",
      "Read(~/.config/gcloud/*)",
      "Edit(~/.ssh/*)",
      "Edit(~/.aws/*)",
      "Edit(~/.gnupg/*)",
      "Edit(~/.config/gcloud/*)",
      "Read(*credentials*)",
      "Read(*.tfvars)",
      "Read(*.tfstate*)",
      "Read(*.sqlite3)",
      "Read(*.sqlite)",
      "Read(dump.sql)",
      "Read(*.docker/config.json)",
      "Read(.kube/config)",
      "Read(*/kubeconfig*)",
      "Read(.npmrc)",
      "Read(.pypirc)",
      "Read(.netrc)",
      "Read(*.jks)",
      "Read(*.keystore)",
      "Read(*google-services.json)",
      "Bash(npx rimraf*)",
      "Bash(kill -9 *)",
      "Bash(killall *)",
      "Bash(docker system prune*)",
      "Bash(docker volume prune*)",
      "Bash(docker container prune*)",
      "Bash(docker image prune*)",
      "Bash(chmod 777*)",
      "Bash(chmod -R 777*)",
      "Bash(dd if=*)",
      "Bash(dd of=*)",
      "Bash(launchctl load*)",
      "Bash(launchctl unload*)",
      "Bash(crontab -r*)",
      "Bash(crontab -e*)",
      "Bash(mkfs*)",
      "Bash(diskutil erase*)",
      "Read(~/PassVault/**)",
      "Read(/Volumes/PassVault/**)",
      "Write(~/PassVault/**)",
      "Write(/Volumes/PassVault/**)",
      "Edit(~/PassVault/**)",
      "Edit(/Volumes/PassVault/**)",
      "Bash(cat ~/PassVault*)",
      "Bash(cat /Volumes/PassVault*)",
      "Bash(less ~/PassVault*)",
      "Bash(less /Volumes/PassVault*)",
      "Bash(head ~/PassVault*)",
      "Bash(tail ~/PassVault*)",
      "Bash(grep * ~/PassVault*)",
      "Bash(grep * /Volumes/PassVault*)",
      "Read(~/Documents/Obsidian Vault/**/*password*)",
      "Read(~/Documents/Obsidian Vault/**/*secret*)",
      "Read(~/Documents/Obsidian Vault/**/*wallet*)",
      "Read(~/Documents/Obsidian Vault/**/*seed*)",
      "Read(~/Documents/Obsidian Vault/**/PassVault/**)"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-fable-5[1m]",
  "skillOverrides": {
    "step1-manuscript": "name-only",
    "step2-menu-register": "name-only",
    "step2-komi-diagnosis": "name-only",
    "step3-ppv-info": "name-only",
    "step4-menu-config": "name-only",
    "step5-mkb-upload": "name-only",
    "step6-izumo-sync": "name-only",
    "step8-subtitle": "name-only",
    "register-all": "name-only",
    "verify-production": "name-only",
    "retitle-product": "off",
    "yudo-recommend": "name-only",
    "headline-optimizer": "name-only",
    "csv-format-converter": "name-only",
    "playwright-browser-automation": "name-only",
    "fetch-bookmarks": "off",
    "fetch-engagement": "name-only",
    "gh-star-harvest": "off",
    "max-scroll-scrape": "off",
    "browser-automation-parallelization": "off",
    "machine-bootstrap": "off",
    "codify-config": "off",
    "env-factcheck": "off",
    "organize-desktop": "name-only",
    "capture-improvement": "name-only",
    "project-bootstrap": "off",
    "notification-alert": "off",
    "health": "name-only",
    "canvas": "name-only",
    "obsidian-bases": "name-only",
    "obsidian-cli": "name-only",
    "obsidian-markdown": "name-only",
    "defuddle": "off",
    "wiki": "name-only",
    "wiki-fold": "name-only",
    "wiki-ingest": "name-only",
    "wiki-lint": "name-only",
    "wiki-query": "off",
    "save": "name-only",
    "autoresearch": "name-only",
    "obsidian-short-note-merge": "name-only",
    "obsidian-now-done": "name-only",
    "dashboard-design-guide": "name-only",
    "data-visualization": "off",
    "data-provenance-first": "name-only",
    "kpi-tree-first": "name-only",
    "sales-analysis": "name-only",
    "salesmtg-dashboard-qa": "off",
    "salesmtg-data-audit": "off",
    "tool-selection-reference": "name-only",
    "skill-lifecycle-reference": "name-only",
    "git-safety-reference": "name-only",
    "frontend-design": "off",
    "claude-api": "name-only",
    "codebase-investigation": "off",
    "collect-reply-posts": "off",
    "config-placement-guide": "off",
    "feature-dev-hybrid": "off",
    "grok-collect-twittora": "off",
    "project-cross-pc-handoff": "off",
    "search-best-practice": "off",
    "secret-vault-setup": "off"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-claude-mem-inject.sh"
          }
        ]
      },
      {
        "matcher": "mcp__playwright__browser_navigate",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/playwright-proxy-guard.py"
          }
        ]
      },
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/plan-readiness-check.sh"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/plan-quality-check.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/plan-forbidden-block.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/verify-step-guard.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/enforce-extension-pattern.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/file-protection.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/restrict-cwd-edits.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/memory-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-dangerous-git.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-host-installs.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/html-preview-guard.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/route-google-workspace.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Read|NotebookRead",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/posttooluse-edit-history.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/check-extension-imports.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f ~/.claude/state/plan-readiness.done ] && ~/.claude/hooks/plan-drift-warn.sh || true"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/vault-moc-sync-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Skill|SlashCommand",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/simplify-done-marker.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/verify-step-auto-reset.sh"
          }
        ]
      },
      {
        "matcher": "mcp__playwright__browser_navigate|mcp__playwright__browser_snapshot|mcp__playwright__browser_console_messages|mcp__playwright__browser_click|mcp__playwright__browser_take_screenshot|mcp__playwright__browser_type|mcp__playwright__browser_fill_form",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/verify-step-playwright-reset.sh"
          }
        ]
      },
      {
        "matcher": "mcp__codex__codex",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/codex-review-tracker.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/data-provenance-guard.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/open-md-in-obsidian.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "(~/.claude/hooks/jsonl-archive.sh) 2>&1 | head -50"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$PWD\" in *make_article*) (~/Desktop/biz/make_article/hooks/improvement-ingest-check.sh) 2>&1 | head -10 ;; esac"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "(~/.claude/hooks/data-retention.sh) 2>&1 | head -50"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "(~/.claude/hooks/verify-step-session-cleanup.sh) 2>&1 | head -50"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "(~/.claude/hooks/checklist-session-cleanup.sh) 2>&1 | head -50"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f ~/.claude/state/recurring-mistakes.md ] && echo '=== ⚠️ Recurring Mistakes (実行時注入ルール) ===' && awk '/^## Active Rules/{f=1;next} /^## メタルール/{f=0} f' ~/.claude/state/recurring-mistakes.md || true"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/vault-sync-sessionstart.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "(~/.claude/hooks/sessionstart-project-registry.sh) 2>&1 | head -45"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "(~/.claude/hooks/sessionstart-env-recall.sh) 2>&1 | head -20"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/sessionstart-github-issues.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/wiki-dormant-warn.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/sessionstart-vault-audit-warning.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "(~/.claude/hooks/wiki-recall-on-prompt.sh) 2>&1 | head -40",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "(~/.claude/hooks/postcompact-essentials.sh) 2>&1 | head -60"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/sessionstart-env-git-drift.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/machine-local-bootstrap.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "(~/.claude/hooks/sessionstart-asa-board.sh) 2>&1 | head -5"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-approve-settings.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-continue-until-green.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-material-auto-capture.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(pwd)\" && [ -d wiki ] && [ -d .git ] && git diff --name-only HEAD 2>/dev/null | grep -q '^wiki/' && echo 'WIKI_CHANGED: Wiki pages were modified this session. Please update wiki/hot.md with a brief summary of what changed (under 500 words). Use the hot cache format: Last Updated, Key Recent Facts, Recent Changes, Active Threads. Keep it factual. Overwrite the file completely. It is a cache, not a journal.' || true"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/implementation-checklist-pending.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/verify-step-pending.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/vault-sync-stop.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-obs-refs-index.sh 2>&1 | head -3"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/wiki-auto-capture-on-stop.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/vault-moc-sync-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-obs-before-claim.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-evidence-footer.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-dup-guard.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-backlog-guard.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/precompact-backup-session.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/precompact-build-restore-note.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f \"$(pwd)/wiki/hot.md\" ] && cat \"$(pwd)/wiki/hot.md\" || true"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/precompact-vault-sync.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/idle-notify.sh"
          }
        ]
      },
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/permission-notify.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-skill-review.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/userprompt-routing-inject.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/userpromptsubmit-edit-recheck-warn.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-goal-gate.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/userpromptsubmit-prompt-history.py",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/subagent-verify-reminder.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "cat | bash ~/.claude/statusline.sh",
    "padding": 2
  },
  "enabledPlugins": {
    "feature-dev@claude-code-plugins": false,
    "claude-mem@thedotmack": true
  },
  "extraKnownMarketplaces": {
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    }
  },
  "spinnerTipsOverride": {
    "excludeDefault": false,
    "tips": [
      "ルーティングテーブル(30-routing.md)確認した？",
