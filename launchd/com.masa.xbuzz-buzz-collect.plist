<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.masa.xbuzz-buzz-collect</string>
  <!-- バズ事例収集の再開（2026-07-18 裁定5/7・約3ヶ月凍結からの再稼働）。
       毎週月 20:30（21:00 の週次ピックが最新コーパスを参照できる順序）。
       XAI_API_KEY は login shell (~/.zshrc) から。コンテナ停止時は即失敗＝ログで検知 -->
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>docker exec -e XAI_API_KEY="$XAI_API_KEY" xstock-vnc python3 /app/scripts/grok_collect_twittora.py</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key><integer>1</integer>
    <key>Hour</key><integer>20</integer>
    <key>Minute</key><integer>30</integer>
  </dict>
  <key>RunAtLoad</key>
  <false/>
  <key>StandardOutPath</key>
  <string>/Users/masaaki_nagasawa/.claude/state/xbuzz-buzz-collect.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/masaaki_nagasawa/.claude/state/xbuzz-buzz-collect.err.log</string>
</dict>
</plist>
