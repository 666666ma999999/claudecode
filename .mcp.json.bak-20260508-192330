{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "sentry": {
      "type": "http",
      "url": "https://mcp.sentry.dev/mcp"
    },
    "firecrawl": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_URL": "http://localhost:3002"
      }
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {
        "MEMORY_FILE_PATH": "${HOME}/.claude/memory/memory.jsonl"
      }
    },
    "postgresql": {
      "command": "npx",
      "args": [
        "-y",
        "@henkey/postgres-mcp-server",
        "--connection-string",
        "${DB_CONNECTION_STRING}"
      ]
    },
    "repomix": {
      "command": "npx",
      "args": [
        "-y",
        "repomix",
        "--mcp"
      ]
    },
    "codex": {
      "type": "stdio",
      "command": "${CODEX_PATH}",
      "args": [
        "mcp-server"
      ],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY}"
      }
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ]
    },
    "grok-search": {
      "command": "npx",
      "args": [
        "-y",
        "grok-search-mcp"
      ],
      "env": {
        "GROK_API_KEY": "${XAI_API_KEY}"
      }
    },
    "mcpvault": {
      "command": "npx",
      "args": [
        "-y",
        "@bitbonsai/mcpvault@latest"
      ],
      "env": {
        "MCPVAULT_PATH": "${HOME}/Documents/Obsidian Vault"
      }
    }
  }
}
