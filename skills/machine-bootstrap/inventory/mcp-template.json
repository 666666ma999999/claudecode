{
  "mcpServers": {
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {
        "MEMORY_FILE_PATH": "${HOME}/.claude/memory/memory.jsonl"
      }
    },
    "postgresql": {
      "command": "npx",
      "args": [
        "-y",
        "@henkey/postgres-mcp-server",
        "--connection-string",
        "${DB_CONNECTION_STRING}"
      ]
    },
    "repomix": {
      "command": "npx",
      "args": ["-y", "repomix", "--mcp"]
    },
    "codex": {
      "type": "stdio",
      "command": "codex",
      "args": ["mcp-server", "-c", "approval_policy=\"never\""]
    },
    "grok-search": {
      "command": "npx",
      "args": ["-y", "grok-search-mcp"],
      "env": {
        "GROK_API_KEY": "${XAI_API_KEY}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--headless", "--browser=chrome"]
    }
  }
}
