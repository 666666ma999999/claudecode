#!/usr/bin/env python3
"""Fetch posts from @twittora_ via xAI Responses API (x_search tool).

Intended to be run weekly (e.g., via launchd). Stdlib only.
Cost: ~$0.4-0.8 per run (Grok-4 + x_search).

Output:
  $VAULT/.raw/twittora/YYYY-MM-DD.md     — frontmatter index + summary
  $VAULT/.raw/twittora/YYYY-MM-DD.jsonl  — one post per line + meta

Env:
  XAI_API_KEY  required (~/.zshrc or ~/.envrc.shared)
  VAULT        defaults to ~/Documents/Obsidian Vault
  TARGET       defaults to twittora_  (without @)
  LOOKBACK     defaults to 7  (days)
"""
from __future__ import annotations

import datetime as dt
import hashlib
import json
import os
import sys
import urllib.error
import urllib.request

UA = "obs-grok-twittora/1.0 (personal use)"
API_URL = "https://api.x.ai/v1/responses"
MODEL = "grok-4"
TIMEOUT = 180


def eprint(msg: str) -> None:
    print(msg, file=sys.stderr)


def sha256_hex(s: str) -> str:
    return hashlib.sha256(s.encode("utf-8")).hexdigest()


def fetch_xai(api_key: str, payload: dict) -> dict:
    body = json.dumps(payload).encode("utf-8")
    req = urllib.request.Request(
        API_URL,
        data=body,
        method="POST",
        headers={
            "Authorization": f"Bearer {api_key}",
            "Content-Type": "application/json",
            "User-Agent": UA,
        },
    )
    with urllib.request.urlopen(req, timeout=TIMEOUT) as r:
        return json.loads(r.read().decode("utf-8"))


def extract_posts(response: dict) -> tuple[list[dict], str]:
    """Extract X post citations and the text summary from a Responses API reply.

    The API shape evolves; try multiple paths defensively.
    """
    posts: list[dict] = []
    summary_text = ""
    seen_urls: set[str] = set()

    def add_citation(c: dict) -> None:
        url = (c.get("url") or c.get("source_url") or "").strip()
        if not url or url in seen_urls:
            return
        if "x.com" in url or "twitter.com" in url:
            seen_urls.add(url)
            posts.append({
                "url": url,
                "title": c.get("title") or "",
                "snippet": c.get("snippet") or c.get("text") or "",
            })

    output = response.get("output") or []
    if isinstance(output, list):
        for item in output:
            if not isinstance(item, dict):
                continue
            for key in ("citations", "annotations", "sources"):
                for c in item.get(key) or []:
                    if isinstance(c, dict):
                        add_citation(c)
            for c in item.get("content") or []:
                if not isinstance(c, dict):
                    continue
                t = c.get("type") or ""
                if t in ("output_text", "text"):
                    summary_text += (c.get("text") or "")
                for sub_key in ("citations", "annotations"):
                    for sub in c.get(sub_key) or []:
                        if isinstance(sub, dict):
                            add_citation(sub)

    # Fallback for top-level citations or text
    for c in response.get("citations") or []:
        if isinstance(c, dict):
            add_citation(c)
    if not summary_text:
        summary_text = response.get("output_text") or response.get("text") or ""

    return posts, summary_text


def render_md(today: str, target: str, lookback: int, posts: list[dict], summary_text: str) -> str:
    lines = [
        "---",
        "type: source-index",
        "source: grok-twittora",
        f"target: \"@{target}\"",
        f"imported: {today}",
        f"posts: {len(posts)}",
        f"lookback_days: {lookback}",
        "status: raw",
        "auto-generated: true",
        "---",
        "",
        f"# Grok x_search: @{target} ({today})",
        "",
        f"**Lookback**: 過去 {lookback} 日 / **Posts**: {len(posts)}",
        "",
        "## Summary (Grok)",
        "",
        (summary_text.strip() or "(no summary)"),
        "",
        "## Posts (Citations)",
        "",
    ]
    for i, p in enumerate(posts, 1):
        title = p.get("title") or "(untitled)"
        lines.append(f"### {i}. {title}")
        lines.append(f"- URL: {p['url']}")
        sn = (p.get("snippet") or "").replace("\n", " ").strip()
        if sn:
            lines.append(f"- Snippet: {sn[:300]}")
        lines.append("")
    return "\n".join(lines)


def main() -> int:
    api_key = os.environ.get("XAI_API_KEY") or ""
    if not api_key:
        eprint("XAI_API_KEY is not set (export in ~/.zshrc or ~/.envrc.shared)")
        return 1

    vault = os.environ.get("VAULT") or os.path.expanduser("~/Documents/Obsidian Vault")
    target = os.environ.get("TARGET") or "twittora_"
    lookback = int(os.environ.get("LOOKBACK") or "7")

    today = dt.date.today().isoformat()
    raw_dir = os.path.join(vault, ".raw", "twittora")
    os.makedirs(raw_dir, exist_ok=True)
    jsonl_path = os.path.join(raw_dir, f"{today}.jsonl")
    md_path = os.path.join(raw_dir, f"{today}.md")

    from_date = (dt.date.today() - dt.timedelta(days=lookback)).isoformat()
    to_date = today
    fetched_at = dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")

    prompt = (
        f"@{target} アカウントの過去 {lookback} 日 ({from_date} 〜 {to_date}) の投稿を"
        f"すべて取得してください。各投稿について：本文全文、投稿日時、URL、いいね数、"
        f"リプライ数、リポスト数 を構造化形式で返してください。"
        f"プロモーション/紹介系投稿は除外し、本人の発信のみに絞ってください。"
    )
    payload = {
        "model": MODEL,
        "tools": [{
            "type": "x_search",
            "x_search": {
                "allowed_x_handles": [target],
                "from_date": from_date,
                "to_date": to_date,
            }
        }],
        "input": prompt,
    }

    try:
        response = fetch_xai(api_key, payload)
    except urllib.error.HTTPError as e:
        body = e.read().decode("utf-8", errors="ignore")
        eprint(f"HTTP {e.code}: {body[:500]}")
        return 1
    except Exception as e:
        eprint(f"ERROR: {e}")
        return 1

    posts, summary_text = extract_posts(response)
    if not posts and not summary_text.strip():
        eprint("WARN: no posts/text in response; writing raw response for debugging")

    with open(jsonl_path, "w", encoding="utf-8") as f:
        for p in posts:
            entry = {
                "source": "grok-twittora",
                "target_handle": target,
                "url": p["url"],
                "title": p.get("title", ""),
                "snippet": p.get("snippet", ""),
                "fetched_at": fetched_at,
                "lookback_days": lookback,
                "url_hash": sha256_hex(p["url"]),
            }
            f.write(json.dumps(entry, ensure_ascii=False) + "\n")
        f.write(json.dumps({
            "_meta": "raw_response_text",
            "summary_text": summary_text[:4000],
            "fetched_at": fetched_at,
        }, ensure_ascii=False) + "\n")

    with open(md_path, "w", encoding="utf-8") as f:
        f.write(render_md(today, target, lookback, posts, summary_text))

    eprint(f"OK: {len(posts)} posts -> {jsonl_path}")
    return 0 if posts or summary_text.strip() else 1


if __name__ == "__main__":
    raise SystemExit(main())
