#!/usr/bin/env bash
set -euo pipefail

# ============================================================
# gogcli セットアップスクリプト
#
# 新PCで ~/.claude を git pull した後に実行する。
# credentials.json の取得 → 配置 → gog auth credentials 登録 → 認証案内
# ============================================================

GOGCLI_CONFIG_DIR="$HOME/.config/gogcli"
CREDENTIALS_FILE="$GOGCLI_CONFIG_DIR/credentials.json"

# --- 色付き出力 ---
info()  { printf '\033[0;36m[INFO]\033[0m  %s\n' "$*"; }
warn()  { printf '\033[0;33m[WARN]\033[0m  %s\n' "$*"; }
error() { printf '\033[0;31m[ERROR]\033[0m %s\n' "$*"; exit 1; }
ok()    { printf '\033[0;32m[OK]\033[0m    %s\n' "$*"; }

# --- Step 0: gog コマンド確認 ---
info "Checking gogcli installation..."
if ! command -v gog &>/dev/null; then
    warn "gogcli not found. Installing..."
    if command -v brew &>/dev/null; then
        brew install steipete/tap/gogcli
    else
        error "brew not found. Install gogcli manually: brew install steipete/tap/gogcli"
    fi
fi
ok "gogcli found: $(which gog)"

# --- Step 1: credentials.json の取得 ---
info "Checking credentials.json..."
mkdir -p "$GOGCLI_CONFIG_DIR"

if [ -f "$CREDENTIALS_FILE" ]; then
    ok "credentials.json already exists at $CREDENTIALS_FILE"
else
    # 方式1: 1Password CLI (op) が使える場合
    if command -v op &>/dev/null; then
        OP_URI="${GOGCLI_CREDENTIALS_OP_URI:-}"
        if [ -n "$OP_URI" ]; then
            info "Fetching credentials.json from 1Password..."
            op read "$OP_URI" > "$CREDENTIALS_FILE"
            chmod 600 "$CREDENTIALS_FILE"
            ok "credentials.json fetched from 1Password"
        else
            warn "GOGCLI_CREDENTIALS_OP_URI not set. Skipping 1Password fetch."
        fi
    fi

    # 方式2: 手動配置
    if [ ! -f "$CREDENTIALS_FILE" ]; then
        echo ""
        warn "credentials.json not found at $CREDENTIALS_FILE"
        echo ""
        echo "  To get credentials.json:"
        echo "  1. Go to https://console.cloud.google.com/apis/credentials"
        echo "  2. Create OAuth 2.0 Client ID (Desktop App)"
        echo "  3. Download the JSON file"
        echo "  4. Place it at: $CREDENTIALS_FILE"
        echo ""
        echo "  Or copy from another PC:"
        echo "    scp other-mac:~/.config/gogcli/credentials.json $CREDENTIALS_FILE"
        echo ""
        echo "  Or from 1Password (install op CLI first):"
        echo "    brew install 1password-cli"
        echo ""
        read -p "  Press Enter after placing credentials.json, or Ctrl+C to abort: "

        if [ ! -f "$CREDENTIALS_FILE" ]; then
            error "credentials.json still not found. Aborting."
        fi
    fi
fi

chmod 600 "$CREDENTIALS_FILE"

# --- Step 2: gog auth credentials 登録 ---
info "Registering credentials with gogcli..."
gog auth credentials "$CREDENTIALS_FILE"
ok "Credentials registered"

# --- Step 3: アカウント認証 ---
ACCOUNT_EMAIL="${GOGCLI_ACCOUNT_EMAIL:-}"

# 既存token確認
if gog auth list 2>&1 | grep -q "@"; then
    ok "Account already authenticated"
    gog auth list
else
    echo ""
    info "No accounts authenticated yet."

    if [ -n "$ACCOUNT_EMAIL" ]; then
        echo "  Running: gog auth add $ACCOUNT_EMAIL --services all"
        echo "  A browser window will open for Google login."
        echo ""
        read -p "  Press Enter to continue: "
        gog auth add "$ACCOUNT_EMAIL" --services all
    else
        echo "  Run manually:"
        echo "    gog auth add your@gmail.com --services all"
        echo ""
        echo "  Tip: Set GOGCLI_ACCOUNT_EMAIL in ~/.envrc.shared to automate this."
    fi
fi

# --- Step 4: 動作確認 ---
echo ""
info "Verifying setup..."
if gog auth list --check 2>&1 | grep -q "valid\|@"; then
    ok "gogcli is ready!"
    gog auth list --check
else
    warn "Setup may be incomplete. Run 'gog auth list --check' to verify."
fi

echo ""
ok "Done! You can now use 'gog sheets read/write' and other commands."
