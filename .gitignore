# プロジェクト固有設定（各プロジェクトのリポジトリで管理）
projects/

# タスク管理（セッションごとの一時データ）
todos/

# ランタイム
statsig/
state/
sessions/
playwright-profile/

# OS
.DS_Store

# Obsidian（端末固有のワークスペース設定・~/.claude を別 vault として登録）
.obsidian/

# Claude設定（~/.claude/で一元管理）
.claude/

# ローカル専用ディレクトリ
backup_local/
jupyter_ml/
whisper2/
whisper3/
firecrawl/
mcp-servers/

