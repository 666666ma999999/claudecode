.mcp.json
.envrc

# バックアップファイル
backups/
*.bak_*
*.bak-*
*.bak

# Playwright MCP キャッシュ
.playwright-mcp/

# ローカル設定（PC固有）
settings.local.json
mcp-needs-auth-cache.json
policy-limits.json
remote-settings.json

# ビルド成果物・キャッシュ
__pycache__/
*.pyc
*.pyo

# テレメトリ・使用データ
telemetry/
usage-data/
metrics/

# アーカイブ
*.tar.gz

# メモリ（セッション固有）
memory/

# Agent Teams（セッション固有・機密情報含有の可能性）
teams/
tasks/

# ステータスライン一時データ
.sl_live/
.sl_usage_log.csv
.sl_quota_start
archives/

# 一時分析スクリプト
tmp_analysis/
tmp_*/

# 端末固有の自動生成ステートファイル（cleanup tick / self-update 記録）
/.last-cleanup
/.last-update-result.json

# daemon ランタイム状態（control.key 等の機密含む・端末固有）
daemon/
daemon.log

# ジョブ実行ランタイム（セッション固有）
jobs/

# Chrome native host wrapper（端末固有・nvm 絶対パス埋込・自動生成 "do not edit"）
chrome/

# Playwright/Chrome ブラウザプロファイル実体（129MB・キャッシュ/Local State 等・端末固有ランタイム）
playwright-line-profile/

# 監査 Phase 3 退避先 (2026-07-04)
/archive/

# 実行ログ (claude-safe-update.log 等・端末固有)
logs/

# マシン依存 symlink（ユーザー名が2台で異なるため各マシンでローカル作成・2026-07-12）
data/bookmarks.jsonl
data/bookmarks-normalized.jsonl
